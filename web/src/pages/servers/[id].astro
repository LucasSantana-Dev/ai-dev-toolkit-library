---
import Base from "../../layouts/Base.astro";
import { getServers } from "../../lib/catalog.ts";

export async function getStaticPaths() {
  const servers = await getServers();
  return servers.map((s) => ({ params: { id: s.id }, props: { server: s } }));
}
const { server } = Astro.props;

const cmd =
  server.transport === "stdio"
    ? `${server.command ?? ""} ${(server.args ?? []).join(" ")}`.trim()
    : server.url ?? "";
---
<Base title={server.name} description={server.description}>
  <p><a href="../">← all servers</a></p>
  <span class="kind kind-server">server</span>
  <h1 style="display: inline;">{server.name}</h1>
  <p style="color: var(--muted);">{server.description}</p>
  <div class="tags" style="margin: 0.75rem 0 1.25rem;">
    <span class="tag">transport: {server.transport}</span>
    {server.tags.map((t) => <span class="tag">{t}</span>)}
  </div>

  <code class="install">npx @lucassantana/adtl add-server {server.id}</code>

  <h2>Command</h2>
  <pre><code>{cmd}</code></pre>

  {server.env && server.env.length > 0 && (
    <>
      <h2>Environment variables</h2>
      <ul>
        {server.env.map((e) => (
          <li>
            <code>{e.name}</code>
            {e.required ? " (required)" : " (optional)"}
            {e.description && <> — {e.description}</>}
          </li>
        ))}
      </ul>
    </>
  )}

  <p style="color: var(--muted); font-size: 0.85rem; margin-top: 1.5rem;">
    {server.homepage && <>Homepage: <a href={server.homepage}>{server.homepage}</a></>}
    {server.license && <> · {server.license}</>}
  </p>
</Base>
