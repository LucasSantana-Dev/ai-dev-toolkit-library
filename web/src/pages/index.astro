---
import Base from "../layouts/Base.astro";
import Card from "../components/Card.astro";
import InstallBlock from "../components/InstallBlock.astro";
import {
  getSkills,
  getServers,
  getCollections,
  getDocs,
  getAgents,
  getHooks,
  getCommands,
  getTools,
} from "../lib/catalog.ts";

const [skills, servers, collections, docs, agents, hooks, commands, tools] = await Promise.all([
  getSkills(),
  getServers(),
  getCollections(),
  getDocs(),
  getAgents(),
  getHooks(),
  getCommands(),
  getTools(),
]);
const base = import.meta.env.BASE_URL;

const featuredSkills = skills.slice(0, 3);
const featuredAgents = agents.slice(0, 3);
const featuredServers = servers.slice(0, 3);
const featuredTools = tools.slice(0, 3);
const featuredHooks = hooks.slice(0, 3);

const total = skills.length + agents.length + servers.length + hooks.length + commands.length + tools.length;

const tagCount = new Map<string, number>();
for (const e of [...skills, ...servers, ...agents, ...hooks, ...tools]) {
  for (const t of e.tags ?? []) tagCount.set(t, (tagCount.get(t) ?? 0) + 1);
}
const popularTags = [...tagCount.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([t]) => t);
---
<Base title="Library">
  <section class="hero">
    <div class="hero-content">
      <h1>The AI-dev toolkit library</h1>
      <p class="lede">
        Curated skills, sub-agents, MCP servers, hooks, commands, and tools for AI-assisted dev.
        Free, self-hosted, inspired by <a href="https://skills.sh">skills.sh</a> and
        <a href="https://app.mcpmarket.com">mcpmarket.com</a>.
      </p>
      <div class="hero-cta">
        <a class="btn btn-primary" href={`${base}skills/`}>Browse {total} entries</a>
        <a class="btn" href="https://github.com/LucasSantana-Dev/ai-dev-toolkit-library/blob/main/docs/QUICKSTART.md">Quickstart ↗</a>
      </div>
      <div style="max-width: 560px; margin: 2rem auto 0;">
        <InstallBlock command="npx @lucassantana/adtl setup --all" label="copy install" />
      </div>
    </div>
  </section>

  <div class="stats">
    <div class="stat"><span class="stat-value">{skills.length}</span><span class="stat-label">Skills</span></div>
    <div class="stat"><span class="stat-value">{agents.length}</span><span class="stat-label">Agents</span></div>
    <div class="stat"><span class="stat-value">{servers.length}</span><span class="stat-label">Servers</span></div>
    <div class="stat"><span class="stat-value">{tools.length}</span><span class="stat-label">Tools</span></div>
    <div class="stat"><span class="stat-value">{hooks.length}</span><span class="stat-label">Hooks</span></div>
    <div class="stat"><span class="stat-value">{commands.length}</span><span class="stat-label">Commands</span></div>
    <div class="stat"><span class="stat-value">{docs.length}</span><span class="stat-label">Docs</span></div>
  </div>

  <h2>Featured collections</h2>
  <p class="lead-muted">Opinionated bundles — one-click starting points.</p>
  <div class="grid">
    {collections.map((c) => (
      <Card
        kind="collection"
        id={c.id}
        name={c.name}
        description={c.description}
        tags={c.tags ?? []}
        href={`${base}collections/${c.id}/`}
        extraTag={`${c.items.length} items`}
      />
    ))}
  </div>

  <h2>Popular skills</h2>
  <div class="grid">
    {featuredSkills.map((s) => (
      <Card kind="skill" id={s.id} name={s.name} description={s.description} tags={s.tags} href={`${base}skills/${s.id}/`} />
    ))}
  </div>
  <p style="margin-top: 1rem;"><a href={`${base}skills/`}>All {skills.length} skills →</a></p>

  <h2>Sub-agents</h2>
  <div class="grid">
    {featuredAgents.map((a) => (
      <Card kind="agent" id={a.id} name={a.name} description={a.description} tags={a.tags} href={`${base}agents/${a.id}/`} extraTag={a.model} />
    ))}
  </div>
  <p style="margin-top: 1rem;"><a href={`${base}agents/`}>All {agents.length} agents →</a></p>

  <h2>MCP servers</h2>
  <div class="grid">
    {featuredServers.map((s) => (
      <Card kind="server" id={s.id} name={s.name} description={s.description} tags={s.tags} href={`${base}servers/${s.id}/`} extraTag={s.transport} />
    ))}
  </div>
  <p style="margin-top: 1rem;"><a href={`${base}servers/`}>All {servers.length} servers →</a></p>

  <h2>Tools</h2>
  <p class="lead-muted">Token optimization, RAG, compression, MCP ops, diagnostics.</p>
  <div class="grid">
    {featuredTools.map((t) => (
      <Card kind="tool" id={t.id} name={t.name} description={t.description} tags={t.tags} href={`${base}tools/${t.id}/`} extraTag={`${t.category} · ${t.runtime}`} />
    ))}
  </div>
  <p style="margin-top: 1rem;"><a href={`${base}tools/`}>All {tools.length} tools →</a></p>

  <h2>Hooks</h2>
  <div class="grid">
    {featuredHooks.map((h) => (
      <Card kind="hook" id={h.id} name={h.name} description={h.description} tags={h.tags} href={`${base}hooks/${h.id}/`} extraTag={h.event} />
    ))}
  </div>
  <p style="margin-top: 1rem;"><a href={`${base}hooks/`}>All {hooks.length} hooks →</a></p>

  <h2>Browse by tag</h2>
  <div class="chips">
    {popularTags.map((t) => (
      <a href={`${base}search/?tag=${encodeURIComponent(t)}`} class="chip">#{t}</a>
    ))}
  </div>
</Base>
