---
import Base from "../../layouts/Base.astro";
import { getCollections } from "../../lib/catalog.ts";

const collections = await getCollections();
const base = import.meta.env.BASE_URL;
---
<Base title="Collections">
  <h1>Collections <span style="color: var(--muted); font-weight: 400; font-size: 1rem;">({collections.length})</span></h1>
  <p style="color: var(--muted); max-width: 640px;">Opinionated bundles for specific workflows.</p>
  <div class="grid" style="margin-top: 1.5rem;">
    {collections.map((c) => (
      <a class="card" href={`${base}collections/${c.id}/`}>
        <span class="kind kind-collection">coll</span>
        <h3 style="display: inline;">{c.name}</h3>
        <p>{c.description}</p>
        <p style="color: var(--muted); font-size: 0.8rem; margin-top: 0.3rem;">{c.items.length} items</p>
      </a>
    ))}
  </div>
</Base>
