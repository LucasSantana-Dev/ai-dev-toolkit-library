---
import Base from "../../layouts/Base.astro";
import { getCollections } from "../../lib/catalog.ts";

export async function getStaticPaths() {
  const collections = await getCollections();
  return collections.map((c) => ({ params: { id: c.id }, props: { collection: c } }));
}
const { collection } = Astro.props;
const base = import.meta.env.BASE_URL;

function kindHref(item: { kind: string; id: string }) {
  const dir = item.kind === "skill" ? "skills" : item.kind === "server" ? "servers" : "docs";
  return `${base}${dir}/${item.id}/`;
}
function kindClass(kind: string) {
  return `kind kind-${kind}`;
}
---
<Base title={collection.name} description={collection.description}>
  <p><a href="../">← all collections</a></p>
  <span class="kind kind-collection">collection</span>
  <h1 style="display: inline;">{collection.name}</h1>
  <p style="color: var(--muted);">{collection.description}</p>

  <h2>Items</h2>
  <div class="grid">
    {collection.items.map((item) => (
      <a class="card" href={kindHref(item)}>
        <span class={kindClass(item.kind)}>{item.kind}</span>
        <h3 style="display: inline;">{item.id}</h3>
      </a>
    ))}
  </div>
</Base>
