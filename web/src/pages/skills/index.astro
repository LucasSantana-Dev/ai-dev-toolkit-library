---
import Base from "../../layouts/Base.astro";
import { getSkills } from "../../lib/catalog.ts";

const skills = await getSkills();
const base = import.meta.env.BASE_URL;
---
<Base title="Skills">
  <h1>Skills <span style="color: var(--muted); font-weight: 400; font-size: 1rem;">({skills.length})</span></h1>
  <p style="color: var(--muted); max-width: 640px;">
    Claude-skill format. Install with <code>npx @lucassantana/adtl install &lt;id&gt;</code>.
  </p>
  <div class="grid" style="margin-top: 1.5rem;">
    {skills.map((s) => (
      <a class="card" href={`${base}skills/${s.id}/`}>
        <span class="kind kind-skill">skill</span>
        <h3 style="display: inline;">{s.name}</h3>
        <p>{s.description}</p>
        <div class="tags">
          {s.tags.slice(0, 6).map((t) => <span class="tag">{t}</span>)}
        </div>
      </a>
    ))}
  </div>
</Base>
