---
import Base from "../../layouts/Base.astro";
import { getSkills } from "../../lib/catalog.ts";

export async function getStaticPaths() {
  const skills = await getSkills();
  return skills.map((s) => ({ params: { id: s.id }, props: { skill: s } }));
}
const { skill } = Astro.props;
---
<Base title={skill.name} description={skill.description}>
  <p><a href="../">← all skills</a></p>
  <span class="kind kind-skill">skill</span>
  <h1 style="display: inline;">{skill.name}</h1>
  <p style="color: var(--muted);">{skill.description}</p>
  <div class="tags" style="margin: 0.75rem 0 1.25rem;">
    {skill.tags.map((t) => <span class="tag">{t}</span>)}
  </div>

  <code class="install">npx @lucassantana/adtl install {skill.id}</code>

  <h2>SKILL.md</h2>
  <pre><code>{skill.body}</code></pre>

  {skill.source?.path && (
    <p style="color: var(--muted); font-size: 0.85rem; margin-top: 1.5rem;">
      Source: <code>{skill.source.path}</code>
      {skill.license && <> · {skill.license}</>}
    </p>
  )}
</Base>
