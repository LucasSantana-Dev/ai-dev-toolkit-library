---
import Base from "../../layouts/Base.astro";
import { getAgents } from "../../lib/catalog.ts";

const agents = await getAgents();
const base = import.meta.env.BASE_URL;
---
<Base title="Agents">
  <h1>Agents <span style="color: var(--muted); font-weight: 400; font-size: 1rem;">({agents.length})</span></h1>
  <p style="color: var(--muted); max-width: 640px;">
    Claude Code sub-agents. Install with <code>npx @lucassantana/adtl install &lt;id&gt;</code>
    — lands in <code>~/.claude/agents/&lt;id&gt;.md</code>.
  </p>
  <div class="grid" style="margin-top: 1.5rem;">
    {agents.map((a) => (
      <a class="card" href={`${base}agents/${a.id}/`}>
        <span class="kind kind-agent">agent</span>
        <h3 style="display: inline;">{a.name}</h3>
        <p>{a.description}</p>
        <div class="tags">
          {a.model && <span class="tag">{a.model}</span>}
          {a.tags.slice(0, 5).map((t) => <span class="tag">{t}</span>)}
        </div>
      </a>
    ))}
  </div>
</Base>
